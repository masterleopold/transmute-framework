{
  "description": "Transmute Framework gate enforcement — validates prerequisites before stage execution",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-prerequisites.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
